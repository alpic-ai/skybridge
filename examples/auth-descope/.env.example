# Descope Configuration
# Find your Project ID at: https://app.descope.com/settings/project
DESCOPE_PROJECT_ID=P2xxxxxxxxxxxxxxxxxx

# MCP Server ID from Descope Console: Resources > MCP Servers > Your MCP Server
# Created when you set up your MCP Server — looks like RSxxxxxxxxxxxxxxxxxx
DESCOPE_MCP_SERVER_ID=RSxxxxxxxxxxxxxxxxxx

# Server URL — leave empty for local dev (auto-detected from port)
# Required when using --tunnel: set this to your tunnel URL before starting
# SERVER_URL=https://your-tunnel-url.alpic.app

# MCP Server audience — the MCP Server URL configured in Descope Console > Resources > MCP Servers >
# Your MCP Server URL + /mcp (e.g. https://your-tunnel-url.alpic.app/mcp)
MCP_AUDIENCE=https://your-tunnel-url.alpic.app/mcp

# Environment
NODE_ENV=development