# Descope Configuration
# Find your Project ID at: https://app.descope.com/settings/project
DESCOPE_PROJECT_ID=P2xxxxxxxxxxxxxxxxxx

# MCP Server ID from Descope Console: Agentic Identity Hub > MCP Servers
# Created when you set up your MCP Server — looks like MSxxxxxxxxxxxxxxxxxx
DESCOPE_MCP_SERVER_ID=MSxxxxxxxxxxxxxxxxxx

# Server URL — leave empty for local dev (auto-detected from port)
# Required when using --tunnel: set this to your tunnel URL before starting
# SERVER_URL=https://your-tunnel-url.alpic.app

# Environment
NODE_ENV=development