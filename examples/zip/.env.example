# Cloudflare R2 (temporary object storage for generated archives).
# When these are set, the server PUTs each archive to R2 and returns a
# presigned GET URL. When absent, it falls back to the in-memory store
# served from /files/:id (local dev only).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Lifetime of the presigned download URL, in seconds (default: 900 = 15 min).
R2_URL_TTL=900
