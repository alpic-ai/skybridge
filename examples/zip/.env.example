# Cloudflare R2 (required — temporary object storage for generated archives).
# The server PUTs each archive to R2 and returns a presigned GET URL.
R2_ACCOUNT_ID=1234567890abcdef1234567890abcdef
R2_ACCESS_KEY_ID=abcd1234efgh5678
R2_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXX
R2_BUCKET=skybridge-zip

# Lifetime of the presigned download URL, in seconds (default: 900 = 15 min).
R2_URL_TTL=900
