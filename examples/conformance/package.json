{
  "name": "conformance",
  "version": "0.0.1",
  "private": true,
  "description": "A self-testing Skybridge app: a stepper that exercises every Skybridge web hook on whatever host renders it and fills a copyable results table.",
  "type": "module",
  "scripts": {
    "dev": "skybridge dev",
    "dev:tunnel": "skybridge dev --tunnel",
    "build": "skybridge build",
    "start": "skybridge start",
    "deploy": "alpic deploy",
    "notte:run": "node --env-file-if-exists=.env notte/run-conformance.ts",
    "notte:profile": "node --env-file-if-exists=.env notte/create-profile.ts",
    "notte:update": "notte functions update --file notte/chatgpt-conformance-function.py"
  },
  "dependencies": {
    "@alpic-ai/ui": "^1.134.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "skybridge": "^1.1.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@skybridge/devtools": "^1.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "alpic": "^1.136.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "workspaces": [],
  "engines": {
    "node": ">=24.0.0"
  }
}
