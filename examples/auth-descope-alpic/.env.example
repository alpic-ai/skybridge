# Descope Configuration
# MCP Server Discovery URL (a.k.a. Issuer) from the console's Connection Information.
# Leave Dynamic Client Registration **disabled** on the MCP Server — Alpic's DCR proxy
# handles client registration when deployed. See README.md for activation steps.
DESCOPE_MCP_SERVER_URL=https://api.descope.com/v1/apps/agentic/<projectId>/<mcpServerId>

# Public URL of this MCP server (used as the advertised authorization server via
# customProvider's serverUrl). Use http://localhost:3000 locally; set to your
# deployed URL on Alpic (or rely on ALPIC_HOST).
SERVER_URL=http://localhost:3000

# Environment
NODE_ENV=development
