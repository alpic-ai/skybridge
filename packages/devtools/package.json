{
  "name": "@skybridge/devtools",
  "version": "1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/alpic-ai/skybridge.git"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && pnpm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "test": "pnpm run test:format && pnpm run test:types && pnpm run test:unit",
    "format": "biome check --write --error-on-warnings",
    "test:format": "biome ci",
    "test:types": "tsc --noEmit -p e2e/tsconfig.json",
    "test:unit": "vitest run",
    "preview": "vite preview",
    "e2e:fixture": "tsx ./e2e/fixtures/server.ts",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@alpic-ai/sdk": "^1.148.0",
    "@t3-oss/env-core": "^0.13.11",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@alpic-ai/ui": "^1.148.0",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@rjsf/core": "^6.6.2",
    "@rjsf/shadcn": "^6.6.2",
    "@rjsf/utils": "^6.6.2",
    "@rjsf/validator-ajv8": "^6.6.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.3",
    "ahooks": "^3.9.7",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.42.2",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "nuqs": "^2.9.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.1",
    "react-syntax-highlighter": "^16.1.1",
    "shadcn": "^4.13.0",
    "shiki": "^4.3.1",
    "skybridge": "workspace:*",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "zustand": "^5.0.14"
  }
}
