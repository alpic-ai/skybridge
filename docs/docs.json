{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Skybridge",
  "theme": "mint",
  "colors": {
    "primary": "#002FFF",
    "light": "#08F5F9",
    "dark": "#002FFF"
  },
  "favicon": {
    "light": "/images/SkybridgeFaviconmidnight.svg",
    "dark": "/images/SkybridgeFaviconwhite.svg"
  },
  "logo": {
    "light": "/images/Skybridgemidnight.svg",
    "dark": "/images/Skybridgewhite(1).svg"
  },
  "search": {
    "prompt": "Search Skybridge docs..."
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "pages": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "get-started/introduction",
              "get-started/quickstart",
              "get-started/architecture"
            ]
          },
          {
            "group": "Build",
            "icon": "drafting-compass",
            "root": "build/index",
            "pages": [
              "build/tools",
              "build/view",
              "build/state",
              "build/auth"
            ],
            "expanded": true
          },
          {
            "group": "Test",
            "icon": "test-tube-diagonal",
            "root": "test/index",
            "pages": [
              "test/devtools",
              "test/tunnel",
              "test/playground",
              "test/audit"
            ],
            "expanded": true
          },
          "ship",
          {
            "group": "Guides",
            "icon": "book-open",
            "root": "guides/index",
            "pages": [
              "guides/csp",
              "guides/ux",
              "guides/files",
              "guides/migrate"
            ],
            "expanded": true
          },
          "troubleshooting",
          {
            "group": "Resources",
            "icon": "library",
            "pages": [
              "resources/apps-sdk-and-mcp-apps",
              "resources/telemetry"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "pages": [
          "api-reference/overview",
          {
            "group": "Server",
            "icon": "server",
            "pages": [
              "api-reference/mcp-server",
              "api-reference/register-tool"
            ]
          },
          {
            "group": "Auth",
            "icon": "lock",
            "pages": [
              "api-reference/mcp-auth-metadata-router",
              "api-reference/optional-bearer-auth",
              "api-reference/require-bearer-auth"
            ]
          },
          {
            "group": "Hooks",
            "icon": "fishing-rod",
            "pages": [
              "api-reference/use-call-tool",
              "api-reference/use-display-mode",
              "api-reference/use-download",
              "api-reference/use-files",
              "api-reference/use-layout",
              "api-reference/use-open-external",
              "api-reference/use-register-view-tool",
              "api-reference/use-request-close",
              "api-reference/use-request-modal",
              "api-reference/use-request-size",
              "api-reference/use-send-follow-up-message",
              "api-reference/use-set-open-in-app-url",
              "api-reference/use-tool-info",
              "api-reference/use-user",
              "api-reference/use-view-state"
            ]
          },
          {
            "group": "Utilities",
            "icon": "toolbox",
            "pages": [
              "api-reference/create-store",
              "api-reference/data-llm",
              "api-reference/generate-helpers"
            ]
          },
          {
            "group": "Types",
            "icon": "type",
            "pages": [
              "api-reference/file-ref",
              "api-reference/utility-types"
            ]
          },
          "api-reference/cli",
          {
            "group": "Low-level",
            "icon": "binary",
            "pages": [
              "api-reference/use-apps-sdk-context",
              "api-reference/use-mcp-app-context"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "pages": [
          "examples",
          {
            "group": "Basic",
            "pages": [
              "examples/starter",
              "examples/everything"
            ]
          },
          {
            "group": "Use cases",
            "pages": [
              "examples/capitals",
              "examples/chess",
              "examples/flight-booking",
              "examples/ecommerce-carousel",
              "examples/investigation-game",
              "examples/productivity",
              "examples/times-up"
            ]
          },
          {
            "group": "Auth",
            "pages": [
              "examples/auth-clerk",
              "examples/auth-workos",
              "examples/auth-stytch",
              "examples/auth-auth0"
            ]
          },
          {
            "group": "UI and Component libraries",
            "pages": [
              "examples/manifest-ui",
              "examples/generative-ui"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/showcase",
      "destination": "/examples"
    },
    {
      "source": "/showcase/:slug*",
      "destination": "/examples/:slug*"
    },
    {
      "source": "/examples/magic-8-ball",
      "destination": "/examples/starter"
    },
    {
      "source": "/examples/awaze",
      "destination": "https://skybridge.tech/showcase"
    },
    {
      "source": "/examples/cottages",
      "destination": "https://skybridge.tech/showcase"
    },
    {
      "source": "/examples/evaneos",
      "destination": "https://skybridge.tech/showcase"
    },
    {
      "source": "/examples/lumo",
      "destination": "https://skybridge.tech/showcase"
    }
  ],
