{
  "name": "@skybridge/monorepo",
  "version": "0.0.0",
  "description": "Skybridge is a framework for building ChatGPT and MCP Apps",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" build",
    "test": "pnpm --filter \"./packages/*\" test",
    "format": "pnpm --filter \"./packages/*\" format",
    "test:unit": "pnpm --filter \"./packages/*\" test:unit",
    "test:type": "pnpm -r test:type",
    "test:format": "pnpm --filter \"./packages/*\" test:format",
    "docs:dev": "pnpm --filter @skybridge/docs dev",
    "bump": "node scripts/bump.js && pnpm i"
  },
  "keywords": [
    "chatgpt",
    "app",
    "ai",
    "skybridge"
  ],
  "author": "Frédéric Barthelet",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@asyncapi/parser>ajv": "^8.18.0",
      "@mintlify/prebuild>js-yaml": "^4.1.1",
      "@mintlify/previewing>js-yaml": "^4.1.1",
      "@mintlify/scraping>js-yaml": "^4.1.1",
      "@mintlify/validation>js-yaml": "^4.1.1",
      "@modelcontextprotocol/sdk>ajv": "^8.18.0",
      "@openai/apps-sdk-ui>lodash": "^4.17.23",
      "@rjsf/validator-ajv8>ajv": "^8.18.0",
      "ahooks>lodash": "^4.17.23",
      "@mintlify/cli>js-yaml": "^4.1.1",
      "@mintlify/common>js-yaml": "^4.1.1",
      "@mintlify/common>lodash": "^4.17.23",
      "@mintlify/models>axios": "^1.13.5",
      "@mintlify/openapi-parser>ajv": "^8.18.0",
      "@mintlify/previewing>express": "^4.20.0",
      "@mintlify/scraping>zod": "3.24.0",
      "@mintlify/validation>lodash": "^4.17.23",
      "@mintlify/validation>zod": "3.24.0",
      "@modelcontextprotocol/sdk>@hono/node-server": "^1.19.10",
      "@modelcontextprotocol/sdk>express-rate-limit": "^8.2.2",
      "@modelcontextprotocol/sdk>hono": "^4.12.7",
      "@stoplight/spectral-core>minimatch": "^10.2.3",
      "@vitest/ui>flatted": "^3.4.2",
      "@workos-inc/node>qs": "^6.14.2",
      "body-parser>qs": "^6.14.2",
      "engine.io>cookie": "^0.7.0",
      "express>qs": "^6.14.2",
      "filelist>minimatch": "^10.2.3",
      "iron-session>cookie": "^0.7.0",
      "nodemon>minimatch": "^10.2.3",
      "get-uri>basic-ftp": "^5.2.0",
      "nuqs>react-router": "^7.12.0",
      "shadcn>diff": "^8.0.3",
      "socket.io>socket.io-parser": "^4.2.6",
      "ts-node>diff": "^4.0.4",
      "vite>rollup": "^4.59.0"
    }
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.14.0"
  }
}
